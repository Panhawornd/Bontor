// Prisma schema for Smart Grade & Career Analyzer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id              Int               @id @default(autoincrement())
  name            String?
  email           String?           @unique
  password        String?
  emailVerified   DateTime?
  image           String?
  provider        String?           @default("credentials")
  providerId      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  grades          Grade[]
  inputs          Input[]
  recommendations Recommendation[]
  chatSessions    ChatSession[]
}


model Input {
  id               Int             @id @default(autoincrement())
  userId           Int?            @map("user_id")
  recommendationId Int?            @map("recommendation_id")
  interestText     String          @map("interest_text") @db.Text
  careerGoals      String?         @map("career_goals") @db.Text
  createdAt        DateTime        @default(now()) @map("created_at")
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  recommendation   Recommendation? @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@map("inputs")
}

model Grade {
  id               Int             @id @default(autoincrement())
  userId           Int?            @map("user_id")
  recommendationId Int?            @map("recommendation_id")
  subject          String
  score            Decimal
  createdAt        DateTime        @default(now()) @map("created_at")
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  recommendation   Recommendation? @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("grades")
}

model University {
  id                   Int      @id @default(autoincrement())
  name                 String
  country              String
  city                 String?
  availablePrograms    String[] @map("available_programs")
  minGrade             Float?   @map("min_grade")
  entranceExam         Boolean? @map("entrance_exam")
  scholarshipAvailable Boolean? @map("scholarship_available")
  scholarshipDetail    String?  @map("scholarship_detail") @db.Text
  locationMaps         String?  @map("location_maps") @db.Text
  tuitionFee           String?  @map("tuition_fee")
  imageUrl             String?  @map("image_url")

  @@map("universities")
}

model Recommendation {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  majors       Json
  jobs         Json
  universities Json
  skillGaps    Json     @map("skill_gaps")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  inputs       Input[]
  grades       Grade[]

  @@map("recommendations")
}

model ChatSession {
  id        Int            @id @default(autoincrement())
  userId    Int            @map("user_id")
  title     String         @default("New Chat")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId Int         @map("session_id")
  role      String      // 'user' or 'assistant'
  content   String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}
