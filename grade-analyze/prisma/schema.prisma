// Prisma schema for Smart Grade & Career Analyzer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:baboo123@localhost:5433/grade_analyzer"
}

model User {
  id              Int               @id @default(autoincrement())
  name            String?
  email           String?           @unique
  password        String?
  emailVerified   DateTime?
  image           String?
  provider        String?           @default("credentials")
  providerId      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  grades          Grade[]
  inputs          Input[]
  recommendations Recommendation[]
  feedback        Feedback[]
  preferences     UserPreferences?
}

model UserPreferences {
  id                Int     @id @default(autoincrement())
  userId            Int     @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workStyle         String? // "teamwork", "solo", "mixed"
  learningStyle     String? // "theory", "practical", "mixed"
  careerFocus       String? // "research", "industry", "entrepreneurship"
  locationPreference String? // "local", "international", "flexible"
  salaryExpectation String? // "high", "moderate", "flexible"
  workLifeBalance   String? // "high", "moderate", "career-focused"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Feedback {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendedMajor  String
  chosenMajor       String?
  feedbackScore     Int?     // 1-5 rating
  feedbackText      String?
  wasHelpful        Boolean?
  wouldRecommend    Boolean?
  createdAt         DateTime @default(now())
}

model TrainingData {
  id                Int      @id @default(autoincrement())
  grades            Json     // Store as JSON for flexibility
  interests         String
  careerGoals       String?
  studyPreference   String?
  recommendedMajor  String
  actualMajor       String?  // What they actually chose
  feedbackScore     Int?     // 1-5 rating
  createdAt         DateTime @default(now())
  isProcessed       Boolean  @default(false) // For ML training
}

model Input {
  id            Int      @id @default(autoincrement())
  userId        Int?     @map("user_id")
  interestText  String   @map("interest_text") @db.Text
  careerGoals   String?  @map("career_goals") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("inputs")
}

model Grade {
  id      Int     @id @default(autoincrement())
  userId  Int?    @map("user_id")
  subject String
  score   Decimal
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("grades")
}

model University {
  id              Int      @id @default(autoincrement())
  name            String
  country         String
  majorsAvailable String[] @map("majors_available")

  @@map("universities")
}

model Recommendation {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  majors     Json
  jobs       Json
  universities Json
  skillGaps  Json     @map("skill_gaps")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("recommendations")
}
