# ============================================
# ML Service Environment Configuration
# ============================================

# API Key for service-to-service authentication
# The Next.js frontend must send this key in the X-API-Key header
# Change this to a strong random value in production!
ML_API_KEY=capstone-ml-secret-key-2026

# Allowed origins (comma-separated)
# Only your Next.js frontend should be allowed
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server binding
# 127.0.0.1 = only accessible from this machine (secure)
# 0.0.0.0   = accessible from network (less secure)
HOST=127.0.0.1
PORT=8000
